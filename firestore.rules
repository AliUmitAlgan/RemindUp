rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function requestOwnsResource() {
      return signedIn() && request.resource.data.userId == request.auth.uid;
    }

    function existingOwnsResource() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    // App data model standard: top-level collections with userId ownership.
    match /goals/{goalId} {
      allow create: if requestOwnsResource();
      allow read, delete: if existingOwnsResource();
      allow update: if existingOwnsResource() &&
        request.resource.data.userId == resource.data.userId;
    }

    match /reminders/{reminderId} {
      allow create: if requestOwnsResource();
      allow read, delete: if existingOwnsResource();
      allow update: if existingOwnsResource() &&
        request.resource.data.userId == resource.data.userId;
    }

    match /users/{uid} {
      allow read, write: if isOwner(uid);

      match /tasks/{taskId} {
        allow read, write: if isOwner(uid);
      }

      match /events/{eventId} {
        allow read, write: if isOwner(uid);
      }

      match /usage/{usageId} {
        allow read, write: if isOwner(uid);
      }

      match /entitlements/{entitlementId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }
    }

    match /user_preferences/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /app_config/{configId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /ai_usage/{docId} {
      allow read, write: if false;
    }

    match /ai_state/{docId} {
      allow read, write: if false;
    }

    match /ai_queue/{docId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
